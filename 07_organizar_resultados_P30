from pathlib import Path
import shutil, glob, os
import pandas as pd

SRC=Path('/mnt/data/P30_work')
DST=Path('/mnt/data/P30')
if DST.exists(): shutil.rmtree(DST)
(DST/'Individual').mkdir(parents=True)
G= DST/'Grupal comparativo'
(G/'General'/'Goniometría').mkdir(parents=True)
(G/'General'/'Control de calidad').mkdir(parents=True)
(G/'WT').mkdir(parents=True)
(G/'SOD1').mkdir(parents=True)
(G/'WT vs SOD1').mkdir(parents=True)

animals=['856','857','859','860','861','862','863','864','865','867']
